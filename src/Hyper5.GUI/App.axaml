<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Hyper5.GUI.App"
             RequestedThemeVariant="Dark">

  <Application.Resources>
    <!-- Compact desktop tokens. Accent is reserved for focus, selection, and
         the one primary action on a page. -->
    <Color x:Key="SystemAccentColor">#C49A54</Color>
    <SolidColorBrush x:Key="BgBrush" Color="#151612" />
    <SolidColorBrush x:Key="ChromeBrush" Color="#10110F" />
    <SolidColorBrush x:Key="SidebarBrush" Color="#12130F" />
    <SolidColorBrush x:Key="PanelBrush" Color="#1A1B17" />
    <SolidColorBrush x:Key="PanelRaisedBrush" Color="#22231D" />
    <SolidColorBrush x:Key="CardBrush" Color="#1A1B17" />
    <SolidColorBrush x:Key="CardBorderBrush" Color="#33342D" />
    <SolidColorBrush x:Key="ElevatedBrush" Color="#292A23" />
    <SolidColorBrush x:Key="NavActiveBrush" Color="#302A1D" />
    <SolidColorBrush x:Key="TextBrush" Color="#ECE9E0" />
    <SolidColorBrush x:Key="MutedBrush" Color="#AAA89F" />
    <SolidColorBrush x:Key="FaintBrush" Color="#74736C" />
    <SolidColorBrush x:Key="AccentBrush" Color="#C49A54" />
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#D8B46E" />
    <SolidColorBrush x:Key="AccentSoftBrush" Color="#E4C986" />
    <SolidColorBrush x:Key="DangerBrush" Color="#C86663" />
    <SolidColorBrush x:Key="DangerHoverBrush" Color="#DC827D" />
    <SolidColorBrush x:Key="SuccessBrush" Color="#78A98A" />
    <SolidColorBrush x:Key="WarningBrush" Color="#C89F55" />
    <SolidColorBrush x:Key="TileHoverBrush" Color="#25261F" />
    <SolidColorBrush x:Key="TileSelectedBrush" Color="#332D1F" />
  </Application.Resources>

  <Application.Styles>
    <FluentTheme />

    <Style Selector="Window">
      <Setter Property="FontFamily" Value="Inter, Segoe UI, sans-serif" />
      <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
    </Style>
    <Style Selector="TextBlock.pageTitle">
      <Setter Property="FontSize" Value="20" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style Selector="TextBlock.eyebrow">
      <Setter Property="FontSize" Value="10" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="LetterSpacing" Value="1.4" />
      <Setter Property="Foreground" Value="{StaticResource FaintBrush}" />
    </Style>
    <Style Selector="TextBlock.sectionTitle">
      <Setter Property="FontSize" Value="10" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="LetterSpacing" Value="1.2" />
      <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
    </Style>
    <Style Selector="TextBlock.fieldLabel">
      <Setter Property="FontSize" Value="11" />
      <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
      <Setter Property="Margin" Value="0,0,0,4" />
    </Style>

    <!-- Surfaces are restrained. Most grouping is created by alignment and
         separators; a surface is used only when it changes interaction. -->
    <Style Selector="Border.surface">
      <Setter Property="Background" Value="{StaticResource PanelBrush}" />
      <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="6" />
    </Style>
    <Style Selector="Border.card">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
      <Setter Property="BorderThickness" Value="0,0,0,1" />
      <Setter Property="Padding" Value="0,0,0,18" />
    </Style>
    <Style Selector="Border.inspector">
      <Setter Property="Background" Value="{StaticResource PanelBrush}" />
      <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
      <Setter Property="BorderThickness" Value="1,0,0,0" />
    </Style>
    <Style Selector="Border.pill">
      <Setter Property="Background" Value="{StaticResource ElevatedBrush}" />
      <Setter Property="CornerRadius" Value="4" />
      <Setter Property="Padding" Value="7,3" />
    </Style>
    <Style Selector="Border.kbd">
      <Setter Property="Background" Value="{StaticResource PanelRaisedBrush}" />
      <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="3" />
      <Setter Property="Padding" Value="5,2" />
    </Style>
    <Style Selector="Border.coverShadow">
      <Setter Property="CornerRadius" Value="5" />
      <Setter Property="BoxShadow" Value="0 3 10 0 #55000000" />
    </Style>
    <Style Selector="Border.coverClip">
      <Setter Property="CornerRadius" Value="5" />
      <Setter Property="ClipToBounds" Value="True" />
      <Setter Property="Background" Value="{StaticResource PanelRaisedBrush}" />
    </Style>

    <Style Selector="TextBox">
      <Setter Property="CornerRadius" Value="4" />
      <Setter Property="MinHeight" Value="32" />
    </Style>
    <Style Selector="ComboBox">
      <Setter Property="CornerRadius" Value="4" />
      <Setter Property="MinHeight" Value="32" />
    </Style>
    <Style Selector="NumericUpDown">
      <Setter Property="CornerRadius" Value="4" />
      <Setter Property="MinHeight" Value="32" />
    </Style>
    <Style Selector="Button">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="CornerRadius" Value="4" />
      <Setter Property="Padding" Value="11,7" />
    </Style>
    <Style Selector="Button.accent">
      <Setter Property="Background" Value="{StaticResource AccentBrush}" />
      <Setter Property="Foreground" Value="White" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Padding" Value="15,8" />
    </Style>
    <Style Selector="Button.accent:pointerover /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{StaticResource AccentHoverBrush}" />
      <Setter Property="Foreground" Value="White" />
    </Style>
    <Style Selector="Button.danger">
      <Setter Property="Background" Value="{StaticResource DangerBrush}" />
      <Setter Property="Foreground" Value="White" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Padding" Value="15,8" />
    </Style>
    <Style Selector="Button.danger:pointerover /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{StaticResource DangerHoverBrush}" />
      <Setter Property="Foreground" Value="White" />
    </Style>
    <Style Selector="Button.ghost">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
      <Setter Property="Padding" Value="10,6" />
    </Style>
    <Style Selector="Button.ghost:pointerover /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{StaticResource ElevatedBrush}" />
      <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
    </Style>
    <Style Selector="ToggleButton.ghost">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
      <Setter Property="Padding" Value="10,6" />
    </Style>
    <Style Selector="ToggleButton.ghost:pointerover /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{StaticResource ElevatedBrush}" />
      <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
    </Style>
    <Style Selector="ToggleButton.ghost:checked /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{StaticResource NavActiveBrush}" />
      <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
      <Setter Property="Foreground" Value="{StaticResource AccentSoftBrush}" />
    </Style>
    <Style Selector="Button.iconButton">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
      <Setter Property="Width" Value="34" />
      <Setter Property="Height" Value="32" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="FontSize" Value="15" />
    </Style>
    <Style Selector="Button.iconButton:pointerover /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{StaticResource ElevatedBrush}" />
      <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
    </Style>
    <Style Selector="Button.captionButton">
      <Setter Property="Width" Value="46" />
      <Setter Property="Height" Value="31" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="CornerRadius" Value="0" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="Button.captionButton:pointerover /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{StaticResource ElevatedBrush}" />
      <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
    </Style>
    <Style Selector="Button.captionButton:pressed /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{StaticResource PanelRaisedBrush}" />
    </Style>
    <Style Selector="Button.captionButton.close:pointerover /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="#C42B1C" />
      <Setter Property="Foreground" Value="White" />
    </Style>
    <Style Selector="Button.captionButton.close:pressed /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="#A52316" />
      <Setter Property="Foreground" Value="White" />
    </Style>
    <Style Selector="ToggleButton.iconButton">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
      <Setter Property="Width" Value="34" />
      <Setter Property="Height" Value="32" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="FontSize" Value="15" />
    </Style>
    <Style Selector="ToggleButton.iconButton:checked /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{StaticResource NavActiveBrush}" />
      <Setter Property="Foreground" Value="{StaticResource AccentSoftBrush}" />
    </Style>
    <Style Selector="GridSplitter.dockSplitter">
      <Setter Property="MinHeight" Value="6" />
      <Setter Property="MinWidth" Value="4" />
    </Style>
    <Style Selector="GridSplitter.dockSplitter:pointerover">
      <Setter Property="Background" Value="{StaticResource AccentBrush}" />
    </Style>

    <!-- Slim navigation rail. Labels remain available in tooltips and the
         selected state is a small, predictable focus treatment. -->
    <Style Selector="Button.segment">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
      <Setter Property="Width" Value="42" />
      <Setter Property="Height" Value="38" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="CornerRadius" Value="4" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="Margin" Value="0,2" />
    </Style>
    <Style Selector="Button.segment:pointerover /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{StaticResource ElevatedBrush}" />
      <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
    </Style>
    <Style Selector="Button.segment.active /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{StaticResource NavActiveBrush}" />
      <Setter Property="Foreground" Value="{StaticResource AccentSoftBrush}" />
      <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
      <Setter Property="BorderThickness" Value="2,0,0,0" />
    </Style>

    <Style Selector="ContextMenu">
      <Setter Property="Background" Value="{StaticResource PanelBrush}" />
      <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="5" />
      <Setter Property="Padding" Value="4" />
    </Style>
    <Style Selector="ContextMenu MenuItem">
      <Setter Property="Padding" Value="9,6" />
      <Setter Property="CornerRadius" Value="3" />
    </Style>
    <Style Selector="ContextMenu Separator">
      <Setter Property="Background" Value="{StaticResource CardBorderBrush}" />
      <Setter Property="Height" Value="1" />
      <Setter Property="Margin" Value="6,3" />
    </Style>
    <Style Selector="TabControl">
      <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="TabItem">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Padding" Value="12,7" />
    </Style>
    <Style Selector="ListBox.console">
      <Setter Property="Background" Value="#0C1015" />
      <Setter Property="FontFamily" Value="Cascadia Mono, Consolas, Courier New, monospace" />
      <Setter Property="FontSize" Value="11" />
    </Style>
    <Style Selector="ListBox.console ListBoxItem">
      <Setter Property="Padding" Value="8,1" />
      <Setter Property="MinHeight" Value="0" />
    </Style>

    <Style Selector="ListBox.tileGrid ListBoxItem">
      <Setter Property="Padding" Value="7" />
      <Setter Property="Margin" Value="0,0,10,12" />
      <Setter Property="CornerRadius" Value="5" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="RenderTransform" Value="translateY(0px)" />
      <Setter Property="Transitions">
        <Transitions>
          <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.1" />
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="ListBox.tileGrid ListBoxItem:pointerover">
      <Setter Property="RenderTransform" Value="translateY(-2px)" />
    </Style>
    <Style Selector="ListBox.tileGrid ListBoxItem:pointerover /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{StaticResource TileHoverBrush}" />
    </Style>
    <Style Selector="ListBox.tileGrid ListBoxItem:selected /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{StaticResource TileSelectedBrush}" />
      <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
    </Style>
    <Style Selector="ListBox.tileGrid ListBoxItem:selected:pointerover /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{StaticResource TileSelectedBrush}" />
      <Setter Property="BorderBrush" Value="{StaticResource AccentHoverBrush}" />
    </Style>
    <Style Selector="ListBox.gameList ListBoxItem">
      <Setter Property="Padding" Value="0" />
      <Setter Property="Margin" Value="0,0,0,1" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
    </Style>
    <Style Selector="ListBox.gameList ListBoxItem:pointerover /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{StaticResource TileHoverBrush}" />
    </Style>
    <Style Selector="ListBox.gameList ListBoxItem:selected /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{StaticResource TileSelectedBrush}" />
      <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
      <Setter Property="BorderThickness" Value="2,0,0,0" />
    </Style>
  </Application.Styles>
</Application>
