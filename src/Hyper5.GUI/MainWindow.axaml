    <DataTemplate x:Key="GridGameTemplate">
      <StackPanel Width="148" Spacing="6">
        <Border Classes="coverShadow" Width="148" Height="148">
          <Border Classes="coverClip">
            <Panel>
              <Border Background="{Binding PlaceholderBrush}" IsVisible="{Binding !HasCover}">
                <TextBlock Text="{Binding Initials}" FontSize="32" FontWeight="Bold"
                           Foreground="#EEF2F8" Opacity="0.88"
                           HorizontalAlignment="Center" VerticalAlignment="Center" />
              </Border>
              <Image Source="{Binding Cover}" Stretch="UniformToFill" IsVisible="{Binding HasCover}" />
            </Panel>
          </Border>
        </Border>
        <StackPanel Spacing="2">
          <TextBlock Text="{Binding Name}" FontSize="12" FontWeight="SemiBold"
                     TextWrapping="Wrap" MaxLines="2" TextTrimming="CharacterEllipsis" />
          <TextBlock Text="{Binding TitleId}" FontSize="10" Foreground="{StaticResource FaintBrush}"
                     IsVisible="{Binding HasTitleId}" />
          <TextBlock Text="{Binding SizeText}" FontSize="10" Foreground="{StaticResource FaintBrush}" />
        </StackPanel>
      </StackPanel>
    </DataTemplate>

    <DataTemplate x:Key="ListGameTemplate">
      <Grid Height="68" Margin="8,0" ColumnDefinitions="Auto,*,Auto,Auto">
        <Border Classes="coverClip" Width="52" Height="52" VerticalAlignment="Center">
          <Panel>
            <Border Background="{Binding PlaceholderBrush}" IsVisible="{Binding !HasCover}">
              <TextBlock Text="{Binding Initials}" FontSize="16" FontWeight="Bold"
                         Foreground="#EEF2F8" HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <Image Source="{Binding Cover}" Stretch="UniformToFill" IsVisible="{Binding HasCover}" />
          </Panel>
        </Border>
        <StackPanel Grid.Column="1" Margin="12,0,16,0" VerticalAlignment="Center" Spacing="3">
          <TextBlock Text="{Binding Name}" FontSize="12" FontWeight="SemiBold"
                     TextTrimming="CharacterEllipsis" />
          <TextBlock Text="{Binding Path}" FontSize="10" Foreground="{StaticResource FaintBrush}"
                     TextTrimming="CharacterEllipsis" />
        </StackPanel>
        <TextBlock Grid.Column="2" Text="{Binding TitleId}" FontSize="10"
                   Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center"
                   Margin="0,0,22,0" IsVisible="{Binding HasTitleId}" />
        <TextBlock Grid.Column="3" Text="{Binding SizeText}" FontSize="10"
                   Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center"
                   Margin="0,0,8,0" />
      </Grid>
    </DataTemplate>
  </Window.Resources>

  <!-- Windows positions its resize frame just outside the work area while a
       window is maximized. Respect that platform-provided inset so content at
       every edge remains visible. -->
  <Grid x:Name="RootLayout" RowDefinitions="32,42,*,26"
        Margin="{Binding OffScreenMargin, RelativeSource={RelativeSource AncestorType=Window}}">
    <!-- Custom chrome keeps the controls consistent with the rest of Hyper5
         while Avalonia continues to provide the native resize frame. -->
    <Border x:Name="TitleBar" Grid.Row="0" Height="32" Background="{StaticResource ChromeBrush}"
            BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="0,0,0,1">
      <Grid ColumnDefinitions="*,Auto">
        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center" Margin="10,0">
          <Image Source="avares://Hyper5.GUI/Assets/Hyper5.ico" Width="18" Height="18"
                  RenderOptions.BitmapInterpolationMode="HighQuality" />
          <TextBlock Text="Hyper5" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" />
          <TextBlock x:Name="VersionText" Text="v0.0.1" FontSize="10"
                     Foreground="{StaticResource FaintBrush}" VerticalAlignment="Center" />
        </StackPanel>
        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
          <Button x:Name="MinimizeButton" Classes="captionButton" ToolTip.Tip="Minimize">
            <Path Width="16" Height="16" Stretch="Uniform" Data="{StaticResource FluentSubtract}"
                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
          </Button>
          <Button x:Name="MaximizeRestoreButton" Classes="captionButton" ToolTip.Tip="Maximize">
            <Path x:Name="MaximizeRestoreGlyph" Width="16" Height="16" Stretch="Uniform" Data="{StaticResource FluentSquare}"
                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
          </Button>
          <Button x:Name="CloseButton" Classes="captionButton close" ToolTip.Tip="Close">
            <Path Width="16" Height="16" Stretch="Uniform" Data="{StaticResource FluentDismiss}"
                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
          </Button>
        </StackPanel>
      </Grid>
    </Border>

    <!-- Command bar intentionally spans the workspace so controls never
         compete with a visible inspector pane. -->
    <Border Grid.Row="1" Background="{StaticResource ChromeBrush}">
      <Grid ColumnDefinitions="56,Auto,18,*" Margin="10,0">
        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="4,0,18,0">
          <TextBlock x:Name="PageEyebrow" Text="LIBRARY" IsVisible="False" />
          <TextBlock x:Name="PageTitle" Text="Library" Classes="pageTitle" />
          <TextBlock x:Name="PageSubtitle" Text="" IsVisible="False" />
        </StackPanel>
        <StackPanel Grid.Column="3" x:Name="LibraryToolbar" Orientation="Horizontal" Spacing="5"
                    HorizontalAlignment="Left" VerticalAlignment="Center">
          <TextBox x:Name="SearchBox" Watermark="Search library" Width="220" />
          <ComboBox x:Name="SortBox" Width="114" SelectedIndex="0">
            <ComboBoxItem Content="Name" />
            <ComboBoxItem Content="Title ID" />
            <ComboBoxItem Content="Install size" />
          </ComboBox>
          <ToggleButton x:Name="GridViewButton" Classes="iconButton" IsChecked="True" ToolTip.Tip="Cover view">
            <Path Width="16" Height="16" Stretch="Uniform" Data="{StaticResource FluentGrid}"
                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}" />
          </ToggleButton>
          <ToggleButton x:Name="ListViewButton" Classes="iconButton" ToolTip.Tip="List view">
            <Path Width="16" Height="16" Stretch="Uniform" Data="{StaticResource FluentList}"
                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}" />
          </ToggleButton>
          <Button x:Name="AddFolderButton" Classes="accent" ToolTip.Tip="Add folder">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <Path Width="16" Height="16" Stretch="Uniform" Data="{StaticResource FluentFolderAdd}" Fill="White" />
              <TextBlock x:Name="AddFolderButtonLabel" Text="Add games" />
            </StackPanel>
          </Button>
          <Button x:Name="RescanButton" Classes="iconButton" ToolTip.Tip="Rescan library">
            <Path Width="16" Height="16" Stretch="Uniform" Data="{StaticResource FluentArrowSync}"
                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
          </Button>
          <Button x:Name="OpenFileButton" Classes="iconButton" ToolTip.Tip="Open file">
            <Path Width="16" Height="16" Stretch="Uniform" Data="{StaticResource FluentDocument}"
                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
          </Button>
          <ToggleButton x:Name="ConsoleToggle" Classes="ghost" ToolTip.Tip="Console"
                        HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <Grid x:Name="ConsoleControllerGlyph" Width="20" Height="20">
                <Path x:Name="ConsolePlayStationGlyph" Stretch="Uniform" Data="{StaticResource PromptPlayStationSquare}" Fill="#F5F7FC" />
                <Path x:Name="ConsoleXboxGlyph" Stretch="Uniform" Data="{StaticResource PromptXboxX}" Fill="#F5F7FC" IsVisible="False" />
              </Grid>
              <Path x:Name="ConsoleStandardGlyph" Width="18" Height="18" Stretch="Uniform"
                    Data="{StaticResource FluentConsole}" Fill="{StaticResource MutedBrush}" IsVisible="False" />
              <TextBlock x:Name="ConsoleToggleLabel" Text="Console" VerticalAlignment="Center" />
            </StackPanel>
          </ToggleButton>
          <ToggleButton x:Name="InspectorToggleButton" Classes="iconButton" ToolTip.Tip="Game details">
            <Grid>
              <Grid x:Name="InspectorControllerGlyph" Width="20" Height="20">
                <Path x:Name="InspectorPlayStationGlyph" Stretch="Uniform" Data="{StaticResource PromptPlayStationTriangle}" Fill="#F5F7FC" />
                <Path x:Name="InspectorXboxGlyph" Stretch="Uniform" Data="{StaticResource PromptXboxY}" Fill="#F5F7FC" IsVisible="False" />
              </Grid>
              <Grid x:Name="InspectorStandardGlyph" Width="16" Height="16" IsVisible="False"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <Path Width="16" Height="16" Stretch="Uniform" Fill="{StaticResource MutedBrush}"
                      Data="{StaticResource FluentInfo}" />
              </Grid>
            </Grid>
          </ToggleButton>
        </StackPanel>
      </Grid>
    </Border>

    <Grid x:Name="WorkspaceGrid" Grid.Row="2" ColumnDefinitions="56,*,0,0" RowDefinitions="*,6,180"
          ClipToBounds="True">
      <!-- Keep the backdrop inside the library viewport so it reflows with
           neighboring inspector width and console height changes. -->
      <Grid Grid.Row="0" Grid.Column="1" Panel.ZIndex="0"
            ClipToBounds="True">
        <Image x:Name="BackdropImage" Stretch="UniformToFill" Opacity="0"
               HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
               IsVisible="False" IsHitTestVisible="False" />
        <Border x:Name="BackdropScrim" Background="#151612" Opacity="0.72"
                IsVisible="False" IsHitTestVisible="False"
                HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
      </Grid>

      <!-- Compact icon rail. The system tooltip is the label; the selected
           state is deliberately subtle and consistent. -->
      <Border Grid.Row="0" Grid.Column="0" Background="{StaticResource SidebarBrush}"
              BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="0,0,1,0">
        <Grid>
          <StackPanel VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,10,0,0">
            <Button x:Name="LibraryTabButton" Classes="segment active" ToolTip.Tip="Library"
                    ><Path Width="17" Height="17" Stretch="Uniform" Data="{StaticResource FluentLibrary}"
                           Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" /></Button>
            <Button x:Name="OptionsTabButton" Classes="segment" ToolTip.Tip="Options">
              <Path Width="17" Height="17" Stretch="Uniform" Data="{StaticResource FluentWrench}"
                    Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
            </Button>
          </StackPanel>
        </Grid>
      </Border>

      <!-- Primary workspace. The library owns the available center area; the
           inspector and console are independent docks. -->
      <Grid Grid.Row="0" Grid.Column="1" Margin="18,12,12,0" RowDefinitions="*">
        <Grid Grid.Row="0">
          <Grid x:Name="LibraryPage">
            <Grid RowDefinitions="Auto,*">
              <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,18,9">
                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                  <TextBlock Text="Installed titles" FontSize="12" Foreground="{StaticResource MutedBrush}" />
                  <Border Classes="pill"><TextBlock x:Name="LibraryCountText" Text="0" FontSize="10" Foreground="{StaticResource MutedBrush}" /></Border>
                </StackPanel>
              </Grid>

              <Grid Grid.Row="1">
                <ListBox x:Name="GameList" Classes="tileGrid" Background="Transparent"
                         SelectionMode="Single" Padding="0"
                         ItemsPanel="{StaticResource GridItemsPanel}"
                         ItemTemplate="{StaticResource GridGameTemplate}">
                  <ListBox.ContextMenu>
                    <ContextMenu x:Name="GameContextMenu" Placement="Pointer">
                      <MenuItem x:Name="CtxLaunch" Header="Launch" FontWeight="SemiBold" />
                      <MenuItem x:Name="CtxOpenFolder" Header="Open game folder" />
                      <Separator />
                      <MenuItem x:Name="CtxCopyPath" Header="Copy path" />
                      <MenuItem x:Name="CtxCopyTitleId" Header="Copy title ID" />
                      <Separator />
                      <MenuItem x:Name="CtxRemove" Header="Remove from library" Foreground="{StaticResource DangerHoverBrush}" />
                    </ContextMenu>
                  </ListBox.ContextMenu>
                </ListBox>

                <StackPanel x:Name="EmptyState" Spacing="8" HorizontalAlignment="Center" VerticalAlignment="Center"
                            IsVisible="False">
                  <TextBlock Text="No games in this library" FontSize="16" FontWeight="SemiBold"
                             HorizontalAlignment="Center" />
                  <TextBlock x:Name="EmptyStateTitle" Text="Your library is empty" FontSize="12"
                             Foreground="{StaticResource MutedBrush}" HorizontalAlignment="Center" />
                  <TextBlock x:Name="EmptyStateHint" Text="Add a folder containing your games to get started."
                             FontSize="11" Foreground="{StaticResource FaintBrush}" HorizontalAlignment="Center" />
                  <Button x:Name="EmptyAddFolderButton" Classes="accent" Content="Add game folder"
                          HorizontalAlignment="Center" Margin="0,5,0,0" />
                </StackPanel>

                <StackPanel x:Name="LoadingState" Spacing="10" HorizontalAlignment="Center" VerticalAlignment="Center"
                            IsVisible="False">
                  <ProgressBar IsIndeterminate="True" Width="180" Height="3" />
                  <TextBlock x:Name="LoadingStateText" Text="Loading library…" FontSize="11"
                             Foreground="{StaticResource MutedBrush}" HorizontalAlignment="Center" />
                </StackPanel>
              </Grid>
            </Grid>
          </Grid>

          <Grid x:Name="OptionsPage" IsVisible="False" Margin="0,0,18,0">
            <TabControl x:Name="OptionsTabControl">
              <TabItem x:Name="GeneralTabItem" Header="General">
                <ScrollViewer>
                  <StackPanel Margin="0,10,0,16" Spacing="18" MaxWidth="840" HorizontalAlignment="Left">
                    <Border Classes="card">
                      <StackPanel Spacing="12">
                        <TextBlock x:Name="EmulationSectionTitle" Classes="sectionTitle" Text="EMULATION" />
                        <Grid ColumnDefinitions="*,Auto"><StackPanel Spacing="2" Margin="0,0,18,0"><TextBlock x:Name="CpuEngineLabel" Text="CPU engine" FontSize="12" /><TextBlock x:Name="CpuEngineDesc" Text="Execution engine used to run game code." FontSize="11" Foreground="{StaticResource MutedBrush}" /></StackPanel><ComboBox Grid.Column="1" x:Name="CpuEngineBox" Width="145" SelectedIndex="0"><ComboBoxItem x:Name="CpuEngineNativeItem" Content="Native" /></ComboBox></Grid>
                        <Grid ColumnDefinitions="*,Auto"><StackPanel Spacing="2" Margin="0,0,18,0"><TextBlock x:Name="StrictLabel" Text="Strict dynlib resolution" FontSize="12" /><TextBlock x:Name="StrictDesc" Text="Fail the launch when an imported symbol cannot be resolved." FontSize="11" Foreground="{StaticResource MutedBrush}" /></StackPanel><ToggleSwitch Grid.Column="1" x:Name="StrictToggle" OnContent="On" OffContent="Off" /></Grid>
                      </StackPanel>
                    </Border>
                    <Border Classes="card">
                      <StackPanel Spacing="12">
                        <TextBlock x:Name="LoggingSectionTitle" Classes="sectionTitle" Text="LOGGING" />
                        <Grid ColumnDefinitions="*,Auto"><StackPanel Spacing="2" Margin="0,0,18,0"><TextBlock x:Name="LogLevelLabel" Text="Log level" FontSize="12" /><TextBlock x:Name="LogLevelDesc" Text="Verbosity of the emulator console output." FontSize="11" Foreground="{StaticResource MutedBrush}" /></StackPanel><ComboBox Grid.Column="1" x:Name="LogLevelBox" Width="145" SelectedIndex="2"><ComboBoxItem x:Name="LogLevelTraceItem" Content="Trace" /><ComboBoxItem x:Name="LogLevelDebugItem" Content="Debug" /><ComboBoxItem x:Name="LogLevelInfoItem" Content="Info" /><ComboBoxItem x:Name="LogLevelWarningItem" Content="Warning" /><ComboBoxItem x:Name="LogLevelErrorItem" Content="Error" /><ComboBoxItem x:Name="LogLevelCriticalItem" Content="Critical" /></ComboBox></Grid>
                        <Grid ColumnDefinitions="*,Auto"><StackPanel Spacing="2" Margin="0,0,18,0"><TextBlock x:Name="TraceImportsLabel" Text="Import trace limit" FontSize="12" /><TextBlock x:Name="TraceImportsDesc" Text="Trace the first N imports per module (0 = off)." FontSize="11" Foreground="{StaticResource MutedBrush}" /></StackPanel><NumericUpDown Grid.Column="1" x:Name="TraceImportsBox" Width="145" Minimum="0" Maximum="4096" Increment="16" Value="0" FormatString="0" /></Grid>
                        <Grid ColumnDefinitions="*,Auto"><StackPanel Spacing="2" Margin="0,0,18,0"><TextBlock x:Name="LogToFileLabel" Text="Log to file" FontSize="12" /><TextBlock x:Name="LogToFileDesc" Text="Mirror emulator output to a log file." FontSize="11" Foreground="{StaticResource MutedBrush}" /></StackPanel><ToggleSwitch Grid.Column="1" x:Name="LogToFileToggle" OnContent="On" OffContent="Off" /></Grid>
                        <Grid ColumnDefinitions="*,Auto"><StackPanel Spacing="2" Margin="0,0,18,0"><TextBlock x:Name="LogFilePathLabel" Text="Log file path" FontSize="12" /><TextBlock x:Name="LogFilePathText" Text="No custom path" FontSize="11" Foreground="{StaticResource MutedBrush}" /></StackPanel><Button Grid.Column="1" x:Name="SelectLogFilePathButton" Classes="ghost" Content="Select…" /></Grid>
                        <Grid ColumnDefinitions="*,Auto"><StackPanel Spacing="2" Margin="0,0,18,0"><TextBlock x:Name="OverrideLogFileLabel" Text="Override log file" FontSize="12" /><TextBlock x:Name="OverrideLogFileDesc" Text="Use the exact file path instead of appending title ID and timestamp." FontSize="11" Foreground="{StaticResource MutedBrush}" /></StackPanel><ToggleSwitch Grid.Column="1" x:Name="OverrideLogFileToggle" OnContent="On" OffContent="Off" /></Grid>
                      </StackPanel>
                    </Border>
                    <Border Classes="card">
                      <StackPanel Spacing="12">
                        <TextBlock x:Name="LauncherSectionTitle" Classes="sectionTitle" Text="LAUNCHER" />
                        <Grid ColumnDefinitions="*,Auto"><StackPanel Spacing="2" Margin="0,0,18,0"><TextBlock x:Name="LanguageLabel" Text="Emulator language" FontSize="12" /><TextBlock x:Name="LanguageDesc" Text="Language used throughout the launcher. Applies immediately." FontSize="11" Foreground="{StaticResource MutedBrush}" /></StackPanel><ComboBox Grid.Column="1" x:Name="LanguageBox" Width="145" DisplayMemberBinding="{Binding NativeName}" /></Grid>
                        <Grid ColumnDefinitions="*,Auto"><StackPanel Spacing="2" Margin="0,0,18,0"><TextBlock x:Name="ControllerButtonsLabel" Text="Controller button icons" FontSize="12" /><TextBlock x:Name="ControllerButtonsDesc" Text="Match action icons to the connected controller." FontSize="11" Foreground="{StaticResource MutedBrush}" /></StackPanel><ToggleSwitch Grid.Column="1" x:Name="ControllerButtonsToggle" OnContent="On" OffContent="Off" IsChecked="True" /></Grid>
                        <Grid ColumnDefinitions="*,Auto"><StackPanel Spacing="2" Margin="0,0,18,0"><TextBlock x:Name="TitleMusicLabel" Text="Title music" FontSize="12" /><TextBlock x:Name="TitleMusicDesc" Text="Loop the selected game's preview music in the library." FontSize="11" Foreground="{StaticResource MutedBrush}" /></StackPanel><ToggleSwitch Grid.Column="1" x:Name="TitleMusicToggle" OnContent="On" OffContent="Off" IsChecked="True" /></Grid>
                        <Grid ColumnDefinitions="*,Auto"><StackPanel Spacing="2" Margin="0,0,18,0"><TextBlock x:Name="DiscordLabel" Text="Discord presence" FontSize="12" /><TextBlock x:Name="DiscordDesc" Text="Show the running game on your Discord profile." FontSize="11" Foreground="{StaticResource MutedBrush}" /></StackPanel><ToggleSwitch Grid.Column="1" x:Name="DiscordToggle" OnContent="On" OffContent="Off" /></Grid>
                      </StackPanel>
                    </Border>
                    <Border Classes="card">
                      <StackPanel Spacing="12">
                        <TextBlock x:Name="AboutSectionTitle" Classes="sectionTitle" Text="ABOUT" />
                         <Grid ColumnDefinitions="*,Auto"><StackPanel Spacing="2"><TextBlock x:Name="GithubLabel" Text="GitHub" FontSize="12" /><TextBlock x:Name="GithubDesc" Text="Source code, issues and project development." FontSize="11" Foreground="{StaticResource MutedBrush}" /></StackPanel><Button x:Name="GithubButton" Grid.Column="1" Classes="ghost" Content="Open GitHub" /></Grid>
                         <Grid ColumnDefinitions="*,Auto"><StackPanel Spacing="2"><TextBlock x:Name="DiscordServerLabel" Text="Discord" FontSize="12" /><TextBlock x:Name="DiscordServerDesc" Text="Join the community, get support and follow development." FontSize="11" Foreground="{StaticResource MutedBrush}" /></StackPanel><Button x:Name="DiscordButton" Grid.Column="1" Classes="ghost" Content="Join Discord" /></Grid>
                         <Border Background="{StaticResource PanelRaisedBrush}" BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1" CornerRadius="5" Padding="12,10">
                           <Grid ColumnDefinitions="*,Auto">
                             <StackPanel Spacing="3" Margin="0,0,16,0">
                               <TextBlock Text="Open-source credits" FontSize="12" FontWeight="SemiBold" />
                               <TextBlock Text="Hyper5 is based on the original Hyper5 project. Credits to Hyper5 and its contributors."
                                          FontSize="11" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" />
                             </StackPanel>
                             <Button x:Name="OriginalRepoButton" Grid.Column="1" Classes="ghost" Content="View Hyper5" VerticalAlignment="Center" />
                           </Grid>
                         </Border>
                      </StackPanel>
                    </Border>
                  </StackPanel>
                </ScrollViewer>
              </TabItem>
              <TabItem x:Name="EnvTabItem" Header="Environment">
                <ScrollViewer>
                  <StackPanel Margin="0,10,0,16" Spacing="18" MaxWidth="840" HorizontalAlignment="Left">
                    <Border Classes="card"><StackPanel Spacing="12">
                      <TextBlock x:Name="EnvSectionTitle" Classes="sectionTitle" Text="ENVIRONMENT VARIABLES" />
                      <TextBlock x:Name="EnvDesc" Text="Switches passed to the emulator as environment variables at launch." FontSize="11" Foreground="{StaticResource MutedBrush}" />
                      <Grid ColumnDefinitions="*,Auto"><StackPanel Spacing="2" Margin="0,0,18,0"><TextBlock Text="HYPER5_BTHID_UNAVAILABLE" FontSize="12" FontFamily="Consolas,monospace" /><TextBlock x:Name="EnvBthidDesc" Text="Report Bluetooth HID as unavailable for titles whose wheel/FFB middleware polls forever.&#10;Leave off normally. Some titles freeze when init fails." FontSize="11" Foreground="{StaticResource MutedBrush}" /></StackPanel><ToggleSwitch Grid.Column="1" x:Name="EnvBthidToggle" OnContent="On" OffContent="Off" /></Grid>
                      <Grid ColumnDefinitions="*,Auto"><StackPanel Spacing="2" Margin="0,0,18,0"><TextBlock Text="HYPER5_DISABLE_IMPORT_LOOP_GUARD" FontSize="12" FontFamily="Consolas,monospace" /><TextBlock x:Name="EnvLoopGuardDesc" Text="Do not force quit titles that repeat the same call for too long.&#10;Try this when a game exits on its own while loading." FontSize="11" Foreground="{StaticResource MutedBrush}" /></StackPanel><ToggleSwitch Grid.Column="1" x:Name="EnvLoopGuardToggle" OnContent="On" OffContent="Off" /></Grid>
                      <Grid ColumnDefinitions="*,Auto"><StackPanel Spacing="2" Margin="0,0,18,0"><TextBlock Text="HYPER5_VK_VALIDATION" FontSize="12" FontFamily="Consolas,monospace" /><TextBlock x:Name="EnvVkValidationDesc" Text="Enable Vulkan validation layers for GPU debugging.&#10;Slow. Requires the Vulkan SDK to be installed." FontSize="11" Foreground="{StaticResource MutedBrush}" /></StackPanel><ToggleSwitch Grid.Column="1" x:Name="EnvVkValidationToggle" OnContent="On" OffContent="Off" /></Grid>
                      <Grid ColumnDefinitions="*,Auto"><StackPanel Spacing="2" Margin="0,0,18,0"><TextBlock Text="HYPER5_DUMP_SPIRV" FontSize="12" FontFamily="Consolas,monospace" /><TextBlock x:Name="EnvDumpSpirvDesc" Text="Dump AGC shaders and their SPIR-V translations to the shader-dumps folder.&#10;Use when reporting shader or rendering bugs." FontSize="11" Foreground="{StaticResource MutedBrush}" /></StackPanel><ToggleSwitch Grid.Column="1" x:Name="EnvDumpSpirvToggle" OnContent="On" OffContent="Off" /></Grid>
                      <Grid ColumnDefinitions="*,Auto"><StackPanel Spacing="2" Margin="0,0,18,0"><TextBlock Text="HYPER5_LOG_DIRECT_MEMORY" FontSize="12" FontFamily="Consolas,monospace" /><TextBlock x:Name="EnvLogDirectMemoryDesc" Text="Log direct memory allocations and failures to the console.&#10;Use when a game aborts or exits during boot." FontSize="11" Foreground="{StaticResource MutedBrush}" /></StackPanel><ToggleSwitch Grid.Column="1" x:Name="EnvLogDirectMemoryToggle" OnContent="On" OffContent="Off" /></Grid>
                      <Grid ColumnDefinitions="*,Auto"><StackPanel Spacing="2" Margin="0,0,18,0"><TextBlock Text="HYPER5_LOG_NP" FontSize="12" FontFamily="Consolas,monospace" /><TextBlock x:Name="EnvLogNpDesc" Text="Log NP (PlayStation Network) library calls to the console." FontSize="11" Foreground="{StaticResource MutedBrush}" /></StackPanel><ToggleSwitch Grid.Column="1" x:Name="EnvLogNpToggle" OnContent="On" OffContent="Off" /></Grid>
                    </StackPanel></Border>
                  </StackPanel>
                </ScrollViewer>
              </TabItem>
            </TabControl>
          </Grid>
        </Grid>

      </Grid>

      <GridSplitter x:Name="ConsoleSplitter" Classes="dockSplitter" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3"
                    ResizeDirection="Rows" ResizeBehavior="PreviousAndNext"
                    Cursor="SizeNorthSouth"
                    Background="{StaticResource CardBorderBrush}" IsVisible="False" />
      <Border Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="3" x:Name="ConsolePanel"
              Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource CardBorderBrush}"
              BorderThickness="0,1,0,0" IsVisible="False">
        <Grid RowDefinitions="32,*">
          <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto,Auto,Auto,Auto" Margin="12,0">
            <TextBlock x:Name="ConsoleSectionTitle" Classes="sectionTitle" Text="CONSOLE" VerticalAlignment="Center" />
            <TextBox Grid.Column="1" FontSize="11" Margin="14,0" x:Name="ConsoleSearchBox" Watermark="Filter output" MaxWidth="260" HorizontalAlignment="Left" Width="220" />
            <CheckBox Grid.Column="2" x:Name="AutoScrollCheck" Content="Auto-scroll" IsChecked="True" FontSize="11" Margin="0,0,10,0" />
            <Button Grid.Column="3" x:Name="DetachConsoleButton" Classes="ghost" Content="Split" FontSize="11" Padding="8,4" Margin="0,0,5,0" />
            <Button Grid.Column="4" x:Name="CopyLogButton" Classes="ghost" Content="Copy" FontSize="11" Padding="8,4" Margin="0,0,5,0" />
            <Button Grid.Column="5" x:Name="ClearLogButton" Classes="ghost" Content="Clear" FontSize="11" Padding="8,4" />
          </Grid>
          <ListBox Grid.Row="1" x:Name="ConsoleList" Classes="console" BorderThickness="0,1,0,0"
                   BorderBrush="{StaticResource CardBorderBrush}">
            <ListBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding Text}" Foreground="{Binding Brush}" TextWrapping="NoWrap" /></DataTemplate></ListBox.ItemTemplate>
          </ListBox>
        </Grid>
      </Border>

      <GridSplitter x:Name="InspectorSplitter" Classes="dockSplitter" Grid.Row="0" Grid.Column="2" Width="4"
                    ResizeDirection="Columns" ResizeBehavior="PreviousAndNext"
                    Cursor="SizeWestEast"
                    Background="{StaticResource CardBorderBrush}" IsVisible="False" />
      <!-- Contextual, user-dismissible game inspector. -->
      <Border Grid.Row="0" Grid.Column="3" x:Name="SelectedGamePanel" Classes="inspector"
              HorizontalAlignment="Stretch" Padding="0" IsVisible="False">
        <Grid RowDefinitions="*,Auto">
          <!-- Details scroll independently at compact heights. The launch
               actions remain available in their own footer instead of
               overflowing into the console dock. -->
          <ScrollViewer Grid.Row="0" Padding="16,14,16,8"
                        MinHeight="0"
                        VerticalScrollBarVisibility="Auto"
                        HorizontalScrollBarVisibility="Disabled">
            <Grid RowDefinitions="Auto,Auto,Auto,Auto">
          <Grid ColumnDefinitions="*,Auto">
            <TextBlock Text="SELECTED GAME" Classes="sectionTitle" VerticalAlignment="Center" />
            <Button Grid.Column="1" x:Name="InspectorCloseButton" Classes="iconButton" ToolTip.Tip="Close details"
                    ><Path Width="16" Height="16" Stretch="Uniform" Data="{StaticResource FluentDismiss}"
                           Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" /></Button>
          </Grid>
          <Border Grid.Row="1" Classes="coverShadow" Width="176" Height="176" Margin="0,14,0,15"
                  HorizontalAlignment="Left">
            <Border Classes="coverClip">
              <Panel x:Name="SelectedCoverPanel">
                <Border Background="{Binding PlaceholderBrush, FallbackValue={x:Null}}" IsVisible="{Binding !HasCover, FallbackValue=False}">
                  <TextBlock Text="{Binding Initials}" FontSize="42" FontWeight="Bold" Foreground="#EEF2F8"
                             HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <Image Source="{Binding Cover}" Stretch="UniformToFill" IsVisible="{Binding HasCover, FallbackValue=False}" />
              </Panel>
            </Border>
          </Border>
          <StackPanel Grid.Row="2" Spacing="6">
            <TextBlock x:Name="SelectedGameTitle" Text="No game selected" FontSize="18" FontWeight="SemiBold"
                       TextWrapping="Wrap" MaxLines="2" />
            <StackPanel x:Name="SelectedBadgesRow" Orientation="Horizontal" Spacing="5" IsVisible="False">
              <Border Classes="pill" IsVisible="{Binding HasTitleId, FallbackValue=False}"><TextBlock Text="{Binding TitleId}" FontSize="10" Foreground="{StaticResource MutedBrush}" /></Border>
              <Border Classes="pill" IsVisible="{Binding HasVersion, FallbackValue=False}"><TextBlock Text="{Binding VersionText}" FontSize="10" Foreground="{StaticResource MutedBrush}" /></Border>
            </StackPanel>
            <TextBlock x:Name="SelectedGamePath" Text="Pick a game from the library, or open an eboot.bin directly."
                       FontSize="10" Foreground="{StaticResource FaintBrush}" TextWrapping="NoWrap"
                       TextTrimming="CharacterEllipsis" />
          </StackPanel>
          <Grid Grid.Row="3" Margin="0,18,0,0" RowDefinitions="Auto,Auto,Auto,Auto" ColumnDefinitions="Auto,*">
            <TextBlock Grid.Row="0" Classes="fieldLabel" Text="Status" />
            <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Spacing="6">
              <Ellipse x:Name="StatusDot" Width="7" Height="7" Fill="{StaticResource FaintBrush}" VerticalAlignment="Center" />
              <TextBlock x:Name="StatusText" Text="Idle" FontSize="11" Foreground="{StaticResource MutedBrush}"
                         TextTrimming="CharacterEllipsis" />
            </StackPanel>
            <TextBlock Grid.Row="1" Classes="fieldLabel" Text="Install size" />
            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding DataContext.SizeText, ElementName=SelectedCoverPanel}"
                       FontSize="11" Foreground="{StaticResource MutedBrush}" />
            <TextBlock Grid.Row="2" Classes="fieldLabel" Text="Version" />
            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding DataContext.VersionText, ElementName=SelectedCoverPanel}"
                       FontSize="11" Foreground="{StaticResource MutedBrush}" />
            <TextBlock Grid.Row="3" Classes="fieldLabel" Text="Title ID" />
            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding DataContext.TitleId, ElementName=SelectedCoverPanel}"
                       FontSize="11" Foreground="{StaticResource MutedBrush}" />
          </Grid>
            </Grid>
          </ScrollViewer>
          <Border Grid.Row="1" Background="{StaticResource PanelBrush}" Padding="16,0,16,14">
            <StackPanel Spacing="6">
              <Button x:Name="OpenGameFolderButton" Classes="ghost" Content="Open game folder" HorizontalAlignment="Stretch" />
              <Button x:Name="LaunchButton" Classes="accent" IsEnabled="False" HorizontalAlignment="Stretch"
                      HorizontalContentAlignment="Stretch" VerticalContentAlignment="Center">
                <Grid ColumnDefinitions="*,20,7,Auto,*">
                  <Grid x:Name="LaunchControllerGlyph" Grid.Column="1" Width="20" Height="20">
                    <Path x:Name="LaunchPlayStationGlyph" Stretch="Uniform" Data="{StaticResource PromptPlayStationCross}" Fill="#F5F7FC" />
                    <Path x:Name="LaunchXboxGlyph" Stretch="Uniform" Data="{StaticResource PromptXboxA}" Fill="#F5F7FC" IsVisible="False" />
                  </Grid>
                  <Path x:Name="LaunchStandardGlyph" Grid.Column="1" Width="16" Height="16" Stretch="Uniform"
                        Data="{StaticResource FluentPlay}" Fill="#F5F7FC"
                        HorizontalAlignment="Center" VerticalAlignment="Center" IsVisible="False" />
                  <TextBlock x:Name="LaunchButtonLabel" Grid.Column="3" Text="Launch" VerticalAlignment="Center" />
                </Grid>
              </Button>
              <Button x:Name="StopButton" Classes="danger" IsEnabled="False" HorizontalAlignment="Stretch"
                      HorizontalContentAlignment="Stretch" VerticalContentAlignment="Center">
                <Grid ColumnDefinitions="*,20,7,Auto,*">
                  <Grid x:Name="StopControllerGlyph" Grid.Column="1" Width="20" Height="20">
                    <Path x:Name="StopPlayStationGlyph" Stretch="Uniform" Data="{StaticResource PromptPlayStationCircle}" Fill="#F5F7FC" />
                    <Path x:Name="StopXboxGlyph" Stretch="Uniform" Data="{StaticResource PromptXboxB}" Fill="#F5F7FC" IsVisible="False" />
                  </Grid>
                  <Path x:Name="StopStandardGlyph" Grid.Column="1" Width="16" Height="16" Stretch="Uniform"
                        Data="{StaticResource FluentStop}" Fill="#F5F7FC"
                        HorizontalAlignment="Center" VerticalAlignment="Center" IsVisible="False" />
                  <TextBlock x:Name="StopButtonLabel" Grid.Column="3" Text="Stop" VerticalAlignment="Center" />
                </Grid>
              </Button>
            </StackPanel>
          </Border>
        </Grid>
      </Border>
    </Grid>

    <!-- IDE-style status bar: useful runtime state, minimal height. -->
    <Grid x:Name="StatusBar" Grid.Row="3" Height="26" Background="{StaticResource ChromeBrush}"
          ColumnDefinitions="*,Auto">
      <TextBlock x:Name="EmulatorPathText" Grid.Column="0" Text="Emulator: locating…" FontSize="10"
                 Foreground="{StaticResource FaintBrush}" VerticalAlignment="Center" Margin="10,0"
                 TextTrimming="CharacterEllipsis" />
      <TextBlock x:Name="StatusBarRight" Grid.Column="1" Text="" FontSize="10"
                 Foreground="{StaticResource FaintBrush}" VerticalAlignment="Center" Margin="10,0" />
    </Grid>
  </Grid>
</Window>
